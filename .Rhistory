## ---- libraries ----
library(readxl)
library(dplyr)
library(tidyr)
library(rlang)
library(stringr)
## ---- parameters ----
chip_file   <- "../base_model_burden/proteomics_base_results.csv"
disease_xls <- "Sun_supplemental_tables.xlsx"
disease_sheet <- "ST7"
chip_p_thresh    <- 0.05 / (11 * 365)   # CHIP proteomics threshold
disease_p_thresh <- 1.7e-5              # disease p-value threshold (log10 scale used later)
## ---- read & clean CHIP data ----
chip_inflam2 <- read.csv(chip_file) %>%
rename(Protein = Phenotype) %>%
mutate(
Protein   = toupper(Protein),
across(c(BETA, N, SE, P), as.numeric),
statistic   = BETA / SE,
chip_significant = P < chip_p_thresh,
) %>%
filter(chip_significant==TRUE)
pos_chip_inflam2 <- chip_inflam2 %>% filter(BETA > 0)
## ---- parameters ----
chip_file   <- "../base_model_burden/proteomics_base_results.csv"
disease_xls <- "Sun_supplemental_tables.xlsx"
disease_sheet <- "ST7"
chip_p_thresh    <- 0.05 / (11 * 365)   # CHIP proteomics threshold
disease_p_thresh <- 1.7e-5              # disease p-value threshold (log10 scale used later)
## ---- read & clean CHIP data ----
chip_inflam2 <- read.csv(chip_file) %>%
rename(Protein = Phenotype) %>%
mutate(
Protein   = toupper(Protein),
across(c(BETA, N, SE, P), as.numeric),
statistic   = BETA / SE,
chip_significant = P < chip_p_thresh,
) %>%
filter(chip_significant==TRUE)
