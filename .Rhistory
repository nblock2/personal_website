variables<-c("WEIGHT","HEIGHT")
for (v in variables) {
Q1 <- quantile(data$v, 0.25, na.rm = TRUE)
Q3 <- quantile(data$v, 0.75, na.rm = TRUE)
IQR_val <- Q3 - Q1
lower_bound <- Q1 - 1.5 * IQR_val
upper_bound <- Q3 + 1.5 * IQR_val
return(data$v < lower_bound | data$v > upper_bound)
}
for (v in variables) {
Q1 <- data %>% quantile(v, 0.25, na.rm = TRUE)
Q3 <- data %>% quantile(v, 0.75, na.rm = TRUE)
IQR_val <- Q3 - Q1
lower_bound <- Q1 - 1.5 * IQR_val
upper_bound <- Q3 + 1.5 * IQR_val
data[,paste(v,"_outlier")]<- data %>% v < lower_bound | v > upper_bound
}
